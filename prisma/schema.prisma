// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

enum Rola {
  PRACOWNIK
  KIEROWNIK
}

enum StatusWniosku {
  OCZEKUJACY
  ZAAKCEPTOWANY
  ODRZUCONY
}

enum KategoriaWydatku {
  ZAKWATEROWANIE
  TRANSPORT
  WYZYWIENIE
  INNE
}

model Uzytkownik {
  id        Int       @id @default(autoincrement())
  imie      String
  nazwisko  String
  email     String    @unique
  haslo     String
  rola      Rola     @default(PRACOWNIK)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  
  zgloszenia           ZgloszenieWydatku[] @relation("ZgloszeniaUzytkownika")
  rozpatrzoneWnioski   ZgloszenieWydatku[] @relation("RozpatrzoneWnioski")
  
  @@map("uzytkownicy")
}

model ZgloszenieWydatku {
  id                  Int              @id @default(autoincrement())
  nazwa               String
  kwota               Float
  dataWydatku         DateTime
  kategoria           KategoriaWydatku
  opis                String?
  status              StatusWniosku   @default(OCZEKUJACY)
  komentarzKierownika String?
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt
  
  uzytkownikId        Int
  uzytkownik          Uzytkownik      @relation("ZgloszeniaUzytkownika", fields: [uzytkownikId], references: [id])
  
  rozpatrzonyPrzezId  Int?
  rozpatrzonyPrzez    Uzytkownik?     @relation("RozpatrzoneWnioski", fields: [rozpatrzonyPrzezId], references: [id])
  
  @@map("zgloszenia_wydatkow")
}
